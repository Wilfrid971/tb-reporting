# ─── TB Reporting — Configuration ─────────────────────────────
# Copier ce fichier en .env et remplir les valeurs.
# Les valeurs CHANGEME doivent être remplacées avant le démarrage.

# ─── Serveur Node ─────────────────────────────────────────────
PORT=5000

# ─── SQL Server Wavesoft ──────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=WAVESOFT_PROD

# Authentification Windows (mettre true pour utiliser le compte du service Windows
# à la place de DB_USER/DB_PASSWORD)
DB_TRUSTED_CONNECTION=false

# Authentification SQL (utilisée si DB_TRUSTED_CONNECTION=false)
DB_USER=tb_reporting
DB_PASSWORD=CHANGEME

# Options de connexion
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_CONNECTION_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000

# ─── Sécurité ─────────────────────────────────────────────────
# Chaîne aléatoire unique par déploiement. Générer avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGEME-generate-a-random-48-byte-hex-string

# ─── SMTP — Envoi des rapports email ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=rapports@client.fr
SMTP_PASS=CHANGEME
SMTP_FROM=TB Reporting <rapports@client.fr>

# ─── Claude / Anthropic AI ────────────────────────────────────
# Clé API propre à ce client.
# Procédure recommandée : 1 workspace Anthropic par client
# (console.anthropic.com → Settings → Workspaces → Create workspace)
# Permet : suivi de conso isolé + limite de dépense mensuelle par client.
ANTHROPIC_API_KEY=CHANGEME
